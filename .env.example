# ── Database & queue (local Docker Compose) ──────────────────────────────
DATABASE_URL=postgresql://pulse:pulse@localhost:5432/pulse
REDIS_URL=redis://localhost:6379

# ── Alibaba Cloud DashScope / Model Studio (LLM + embeddings) ────────────
# Setup guide: docs/dashscope-setup.md  (DashScope == Model Studio == Bailian)
# Singapore (International) standard key — do NOT use China-region or sk-sp- coding keys
DASHSCOPE_API_KEY=sk-...
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# v3 caps at 1024 dims; schema is vector(1536) → default to v4. Leave as-is.
EMBED_MODEL=text-embedding-v4
EMBED_DIMENSIONS=1536
LLM_MODEL=qwen-plus

# ── Microsoft Entra ID (single app registration; MSAL Node OIDC in NestJS) ─
# Redirect URI in Entra: http://localhost:4000/auth/callback
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:4000/auth/callback

# ── Entra security group object IDs (JWT 'groups' claim → RBAC) ──────────
ENTRA_PULSE_ADMIN_GROUP_ID=
ENTRA_PULSE_MEMBER_GROUP_ID=
ENTRA_PULSE_VIEWER_GROUP_ID=

# ── API server ───────────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000

# ── Frontend URLs (post-login redirect targets; CORS allowlist) ─────────
BOARD_URL=http://localhost:3000
INTEL_URL=http://localhost:3001

# Next.js frontends read this for API calls (copy to apps/board/.env.local etc. or export)
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── JWT (NestJS issues session tokens after Entra OIDC) ─────────────────
JWT_SECRET=generate-a-strong-random-string

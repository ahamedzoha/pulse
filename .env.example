# ── Database & queue (local Docker Compose) ──────────────────────────────
DATABASE_URL=postgresql://pulse:pulse@localhost:5432/pulse
REDIS_URL=redis://localhost:6379

# ── Alibaba Cloud DashScope (LLM + embeddings) ───────────────────────────
# International endpoint — do not use China-region URL
DASHSCOPE_API_KEY=sk-...

# ── Microsoft Entra ID (single app registration; MSAL Node OIDC in NestJS) ─
# Redirect URI in Entra: http://localhost:4000/auth/callback
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:4000/auth/callback

# ── Entra security group object IDs (JWT 'groups' claim → RBAC) ──────────
ENTRA_PULSE_ADMIN_GROUP_ID=
ENTRA_PULSE_MEMBER_GROUP_ID=
ENTRA_PULSE_VIEWER_GROUP_ID=

# ── API server ───────────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000

# ── Frontend URLs (post-login redirect targets; CORS allowlist) ─────────
BOARD_URL=http://localhost:3000
INTEL_URL=http://localhost:3001

# ── JWT (NestJS issues session tokens after Entra OIDC) ─────────────────
JWT_SECRET=generate-a-strong-random-string
